# Copy to .env and fill in real values. NEVER commit .env (CLAUDE.md §10).

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL ---
POSTGRES_DB=chamneul
POSTGRES_USER=chamneul
POSTGRES_PASSWORD=replace-with-a-local-password

# Host perspective: talk to the compose-exposed Postgres port.
# Inside docker compose, the app service overrides these to DB_HOST=db / DB_PORT=5432.
DB_HOST=localhost
DB_PORT=15432
